---
import Layout from '../layouts/Layout.astro';
import { getLessons, getVocab, getGrammar, getKanji } from '../lib/supabase';

const lessons = await getLessons();
const vocab = await getVocab();
const grammar = await getGrammar();
const kanji = await getKanji();
---

<Layout title="Accueil" active="home">
  <h2>&#x1F3AF; Tableau de bord JLPT N5</h2>

  <div class="stats">
    <div class="stat">
      <div class="number">{lessons.length}</div>
      <div class="label">Lecons</div>
    </div>
    <div class="stat">
      <div class="number">{vocab.length}</div>
      <div class="label">Vocabulaire</div>
    </div>
    <div class="stat">
      <div class="number">{grammar.length}</div>
      <div class="label">Grammaire</div>
    </div>
    <div class="stat">
      <div class="number">{kanji.length}</div>
      <div class="label">Kanji</div>
    </div>
  </div>

  <div class="section">
    <h3>&#x1F4DA; Dernieres lecons</h3>
    <div class="card-grid">
      {lessons.slice(-6).reverse().map(l => (
        <a href={`/lecons/${l.id}`} class="card">
          <h3 class="jp">{l.title}</h3>
          <div class="meta">{l.id} {l.lesson_date ? `| ${l.lesson_date}` : ''}</div>
          <div style="margin-top: 0.5rem">
            {(l.tags || []).slice(0, 3).map(t => <span class="tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="section" style="margin-top: 1.5rem">
    <h3>&#x6F22; Kanji du jour</h3>
    <div class="kanji-grid">
      {kanji.sort(() => 0.5 - Math.random()).slice(0, 4).map(k => (
        <div class="kanji-card">
          <div class="char jp">{k.character}</div>
          <div class="meaning">{k.meaning_fr}</div>
          <div class="readings jp">
            <span>{k.onyomi}</span> | <span>{k.kunyomi}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
